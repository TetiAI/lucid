# ============================================================
# Lucid SDK — Environment Variables
# ============================================================

# Database (required for PrismaStore)
DATABASE_URL="postgresql://user:password@localhost:5432/mydb"

# LLM API — works with any OpenAI-compatible provider
LUCID_API_KEY="sk-..."

# Provider base URL:
# LUCID_BASE_URL="https://api.together.xyz/v1"         # Together AI
# LUCID_BASE_URL="https://api.groq.com/openai/v1"      # Groq
# LUCID_BASE_URL="http://localhost:11434/v1"            # Ollama
# LUCID_BASE_URL="https://openrouter.ai/api/v1"        # OpenRouter

# Analysis model (default: meta-llama/Llama-3.1-8B-Instruct-Turbo)
LUCID_MODEL="meta-llama/Llama-3.1-8B-Instruct-Turbo"
# LUCID_MODEL="google/gemini-2.5-flash-lite"
